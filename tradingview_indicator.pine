//@version=6
indicator("Aladdin Institutional AI Multi-Factor Market Intelligence Indicator", shorttitle="Aladdin AI", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// =========================================================================
// 1. INPUT PARAMETERS (USER CONFIGURATIONS)
// =========================================================================
gp_sys       = "SYSTEM CONFIGURATION"
sys_mode     = input.string("BALANCED", title="Operating Mode", options=["CONSERVATIVE", "BALANCED", "AGGRESSIVE"], group=gp_sys)
min_rr       = input.float(1.5, title="Minimum Reward-to-Risk Ratio", step=0.1, group=gp_sys)

gp_modules   = "MODULE TOGGLES"
enable_trend = input.bool(true, title="Enable Trend Engine", group=gp_modules)
enable_momen = input.bool(true, title="Enable Momentum Engine", group=gp_modules)
enable_volum = input.bool(true, title="Enable Volume Engine", group=gp_modules)
enable_struct= input.bool(true, title="Enable Structure Engine", group=gp_modules)
enable_smc   = input.bool(true, title="Enable Smart Money Concepts", group=gp_modules)
enable_volat = input.bool(true, title="Enable Volatility Engine", group=gp_modules)
enable_mtf   = input.bool(true, title="Enable Multi-Timeframe Alignment", group=gp_modules)
enable_pat   = input.bool(true, title="Enable Pattern Recognition", group=gp_modules)

gp_trend     = "A. TREND QUALITY"
ema_fast_len = input.int(20, title="Fast EMA Period", group=gp_trend)
sma_slow_len = input.int(200, title="Slow SMA Period", group=gp_trend)
adx_len      = input.int(14, title="ADX Period", group=gp_trend)
adx_limit    = input.int(20, title="ADX Threshold", group=gp_trend)

gp_momentum  = "B. MOMENTUM QUALITY"
rsi_len      = input.int(14, title="RSI Length", group=gp_momentum)
rsi_ob       = input.int(70, title="RSI Overbought", group=gp_momentum)
rsi_os       = input.int(30, title="RSI Oversold", group=gp_momentum)
macd_fast    = input.int(12, title="MACD Fast Period", group=gp_momentum)
macd_slow    = input.int(26, title="MACD Slow Period", group=gp_momentum)
macd_signal  = input.int(9, title="MACD Signal Period", group=gp_momentum)

gp_volume    = "C. VOLUME & PARTICIPATION"
vol_ma_len   = input.int(20, title="Volume SMA Period", group=gp_volume)
vol_spike_m  = input.float(1.5, title="Volume Spike Multiplier", step=0.1, group=gp_volume)

gp_structure = "D. MARKET STRUCTURE"
pivot_len    = input.int(5, title="Swing Pivot Lookback", minval=2, group=gp_structure)

gp_smc       = "E. SMART MONEY CONCEPTS"
fvg_threshold= input.float(0.1, title="FVG Min Height (ATR Ratio)", step=0.05, group=gp_smc)
show_ob      = input.bool(true, title="Show Order Blocks", group=gp_smc)

gp_location  = "F. FAIR VALUE LOCATION"
vwap_dev_mult= input.float(2.0, title="VWAP Deviation Band Multiplier", step=0.5, group=gp_location)

gp_volatility= "G. VOLATILITY ENGINE"
atr_len      = input.int(14, title="ATR Length", group=gp_volatility)
atr_stop_m   = input.float(2.0, title="ATR Stop Loss Multiplier", step=0.1, group=gp_volatility)

gp_mtf       = "H. MULTI-TIMEFRAME ALIGNMENT"
htf_res      = input.timeframe("240", title="Higher Timeframe", group=gp_mtf)

gp_session   = "I. SESSION RULES"
use_session  = input.bool(false, title="Restrict Trading Session", group=gp_session)
session_time = input.session("0915-1530:23456", title="Trading Session Times", group=gp_session)

gp_ui        = "J. TELEMETRY DISPLAY"
show_dash    = input.bool(true, title="Show Telemetry Dashboard", group=gp_ui)
dash_pos     = input.string("top_right", title="Dashboard Position", options=["top_right", "bottom_right", "top_left", "bottom_left"], group=gp_ui)

// =========================================================================
// 2. HELPER FUNCTIONS (GLOBAL SCOPE)
// =========================================================================
get_position(string pos_str) =>
    switch pos_str
        "top_right"    => position.top_right
        "bottom_right" => position.bottom_right
        "top_left"     => position.top_left
        "bottom_left"  => position.bottom_left
        => position.top_right

cell_format(table t, int col, int row, string txt, color text_c, color bg_c) =>
    table.cell(t, col, row, txt, text_color=text_c, bgcolor=bg_c, text_size=size.small, text_halign=text.align_left)

// =========================================================================
// 3. CORE TECHNICAL INDICATORS
// =========================================================================
ema_fast = ta.ema(close, ema_fast_len)
sma_slow = ta.sma(close, sma_slow_len)
slope_fast = (ema_fast - ema_fast[5]) / (ta.atr(atr_len) * 5) * 100

// ADX & DMI
[di_plus, di_minus, adx_val] = ta.dmi(adx_len, adx_len)

// RSI & Stochastic RSI
rsi_val = ta.rsi(close, rsi_len)
stoch_rsi_val = ta.sma(ta.stoch(rsi_val, rsi_val, rsi_val, rsi_len), 3)

// MACD
[macd_line, macd_sig, macd_hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)
hist_deriv = macd_hist - macd_hist[1]

// Volume & RVOL
vol_sma = ta.sma(volume, vol_ma_len)
rvol = volume / (vol_sma > 0 ? vol_sma : 1)
is_vol_spike = rvol >= vol_spike_m

// Volume Demand Imbalance (Buy vs Sell Volume delta approximation)
candle_range = high - low
bull_vol_ratio = candle_range > 0 ? (close - low) / candle_range : 0.5
buy_vol = volume * bull_vol_ratio
sell_vol = volume * (1.0 - bull_vol_ratio)

avg_buy_vol = ta.sma(buy_vol, 14)
avg_sell_vol = ta.sma(sell_vol, 14)
tot_vol_sum = avg_buy_vol + avg_sell_vol
buy_pct = tot_vol_sum > 0 ? (avg_buy_vol / tot_vol_sum) * 100 : 50.0
sell_pct = tot_vol_sum > 0 ? (avg_sell_vol / tot_vol_sum) * 100 : 50.0

// Volatility & Bands
atr = ta.atr(atr_len)
atr_pct = (atr / close) * 100
bb_basis = ta.sma(close, 20)
bb_dev = ta.stdev(close, 20)
bb_upper = bb_basis + (2 * bb_dev)
bb_lower = bb_basis - (2 * bb_dev)
is_squeezed = bb_upper - bb_lower < 1.5 * ta.atr(20)

// Session check
in_session = not use_session or not na(time(timeframe.period, session_time))

// Dynamic VWAP Bands
var float vwap_sum = na
var float vol_sum = na
if nz(ta.change(time("D"))) != 0
    vwap_sum := 0.0
    vol_sum := 0.0
vwap_sum := nz(vwap_sum) + (close * volume)
vol_sum := nz(vol_sum) + volume
vwap_val = vwap_sum / (vol_sum > 0 ? vol_sum : 1)

// =========================================================================
// 4. REGIME DETECTOR
// =========================================================================
eff_num = math.abs(close - close[10])
eff_denom = 0.0
for i = 0 to 9
    eff_denom := eff_denom + math.abs(close[i] - close[i+1])
price_efficiency = eff_denom > 0 ? eff_num / eff_denom : 1.0

string regime = "Sideways / Range"
int regime_type = 0 // 0 = Sideways, 1 = Trending, 2 = Breakout, 3 = Volatile

is_trending = adx_val >= adx_limit and price_efficiency >= 0.45
is_volatile = atr_pct >= ta.sma(atr_pct, 100) * 1.5

if (is_volatile)
    regime := "Volatile Disorder ⚠️"
    regime_type := 3
else if (is_squeezed)
    regime := "Volatility Squeeze 🤐"
    regime_type := 2
else if (is_trending)
    if (close > sma_slow and slope_fast > 0)
        regime := "Strong Uptrend 📈"
        regime_type := 1
    else if (close < sma_slow and slope_fast < 0)
        regime := "Strong Downtrend 📉"
        regime_type := 1
    else
        regime := "Weak Trend / Pullback 🔄"
        regime_type := 1
else
    regime := "Sideways Range 📊"
    regime_type := 0

// =========================================================================
// 5. PRICE STRUCTURE ENGINE (swing pivots, BOS, CHoCH)
// =========================================================================
// Track structural swing points
var float swing_high = na
var float swing_low = na
var float prev_swing_high = na
var float prev_swing_low = na

ph = ta.pivothigh(high, pivot_len, pivot_len)
pl = ta.pivotlow(low, pivot_len, pivot_len)

if (not na(ph))
    prev_swing_high := swing_high
    swing_high := ph
if (not na(pl))
    prev_swing_low := swing_low
    swing_low := pl

// Track BOS & CHoCH states
var bool is_bullish_trend = true
var bool is_choch = false
var bool is_bos = false

bool bullish_bos = false
bool bearish_bos = false
bool bullish_choch = false
bool bearish_choch = false

if (not na(swing_high) and not na(swing_low))
    if (is_bullish_trend)
        // In an uptrend, breaking the last swing high is a BOS
        if (ta.crossover(close, swing_high))
            bullish_bos := true
            is_bos := true
            is_choch := false
        // In an uptrend, breaking the last swing low is a bearish CHoCH
        else if (ta.crossunder(close, swing_low))
            bearish_choch := true
            is_bullish_trend := false
            is_choch := true
            is_bos := false
    else
        // In a downtrend, breaking the last swing low is a BOS
        if (ta.crossunder(close, swing_low))
            bearish_bos := true
            is_bos := true
            is_choch := false
        // In a downtrend, breaking the last swing high is a bullish CHoCH
        else if (ta.crossover(close, swing_high))
            bullish_choch := true
            is_bullish_trend := true
            is_choch := true
            is_bos := false

// Construct structure brief
string structure_brief = "Neutral Structure"
color struct_color = color.white

if (bullish_choch)
    structure_brief := "Bullish Reversal (CHoCH)"
    struct_color := color.green
else if (bearish_choch)
    structure_brief := "Bearish Reversal (CHoCH)"
    struct_color := color.red
else if (bullish_bos)
    structure_brief := "Bullish Expansion (BOS)"
    struct_color := color.green
else if (bearish_bos)
    structure_brief := "Bearish Expansion (BOS)"
    struct_color := color.red
else if (not na(swing_high) and not na(prev_swing_high) and not na(swing_low) and not na(prev_swing_low))
    if (swing_high > prev_swing_high and swing_low > prev_swing_low)
        structure_brief := "Bullish Trend (HH/HL)"
        struct_color := color.green
    else if (swing_high < prev_swing_high and swing_low < prev_swing_low)
        structure_brief := "Bearish Trend (LH/LL)"
        struct_color := color.red
    else if (swing_high < prev_swing_high and swing_low > prev_swing_low)
        structure_brief := "Symmetrical Squeeze (Inside)"
        struct_color := color.orange
    else if (swing_high > prev_swing_high and swing_low < prev_swing_low)
        structure_brief := "Broadening Range"
        struct_color := color.orange
    else
        structure_brief := is_bullish_trend ? "Bullish Structure" : "Bearish Structure"
        struct_color := is_bullish_trend ? color.green : color.red
else
    structure_brief := "Establishing Structure"
    struct_color := color.gray

// =========================================================================
// 6. SMART MONEY CONCEPTS (FVG & OB Detection)
// =========================================================================
// Fair Value Gaps (FVG)
bool bullish_fvg = low[0] > high[2] and (low[0] - high[2]) > (fvg_threshold * atr)
bool bearish_fvg = high[0] < low[2] and (low[2] - high[0]) > (fvg_threshold * atr)

// Order Blocks (OB)
var box bullish_ob_box = na
var box bearish_ob_box = na

if (bullish_bos and show_ob)
    box.delete(bullish_ob_box)
    bullish_ob_box := box.new(left=bar_index - 5, top=nz(high[5], high), right=bar_index, bottom=nz(low[5], low), border_color=color.new(#10b981, 80), bgcolor=color.new(#10b981, 95))
if (bearish_bos and show_ob)
    box.delete(bearish_ob_box)
    bearish_ob_box := box.new(left=bar_index - 5, top=nz(high[5], high), right=bar_index, bottom=nz(low[5], low), border_color=color.new(#ef4444, 80), bgcolor=color.new(#ef4444, 95))

// =========================================================================
// 7. MULTI-TIMEFRAME ANALYSIS (No-Lookahead Security)
// =========================================================================
htf_ema_fast = request.security(syminfo.tickerid, htf_res, ta.ema(close, ema_fast_len)[1], barmerge.gaps_off, barmerge.lookahead_off)
htf_sma_slow = request.security(syminfo.tickerid, htf_res, ta.sma(close, sma_slow_len)[1], barmerge.gaps_off, barmerge.lookahead_off)
htf_trend_bullish = htf_ema_fast > htf_sma_slow

// =========================================================================
// 8. PATTERN RECOGNITION (Candlestick Patterns)
// =========================================================================
body = math.abs(close - open)
range_c = high - low
is_bullish = close >= open
is_bearish = close < open

body_top = math.max(open, close)
body_bottom = math.min(open, close)
upper_shadow = high - body_top
lower_shadow = body_bottom - low
avg_range = ta.sma(range_c, 10)

is_hammer_shape = lower_shadow >= body * 2 and upper_shadow <= range_c * 0.1 and range_c > avg_range * 0.4
is_shooting_star = upper_shadow >= body * 2 and lower_shadow <= range_c * 0.1 and range_c > avg_range * 0.4
is_bullish_engulfing = is_bearish[1] and is_bullish and open <= close[1] and close >= open[1] and body > body[1]
is_bearish_engulfing = is_bullish[1] and is_bearish and open >= close[1] and close <= open[1] and body > body[1]

// =========================================================================
// 9. AI CONFLUENCE ENGINE (Weighted Scores)
// =========================================================================
float w_trend  = 0.20
float w_momen  = 0.15
float w_volum  = 0.15
float w_struct = 0.20
float w_smc    = 0.15
float w_volat  = 0.10
float w_mtf    = 0.05

if (regime_type == 1) // Trending
    w_trend  := 0.30
    w_struct := 0.20
    w_mtf    := 0.10
    w_momen  := 0.10
    w_volum  := 0.10
    w_smc    := 0.15
    w_volat  := 0.05
else if (regime_type == 0) // Ranging
    w_momen  := 0.25
    w_smc    := 0.20
    w_trend  := 0.05
    w_struct := 0.10
    w_volat  := 0.15
    w_volum  := 0.10
    w_mtf    := 0.15

// Scores [-100, 100]
float t_score = 0.0
if (close > ema_fast)
    t_score := t_score + 40
if (close > sma_slow)
    t_score := t_score + 40
if (slope_fast > 0)
    t_score := t_score + 20
if (close < ema_fast)
    t_score := t_score - 40
if (close < sma_slow)
    t_score := t_score - 40
if (slope_fast < 0)
    t_score := t_score - 20

float m_score = 0.0
if (rsi_val > 50)
    m_score := m_score + 30
if (macd_hist > 0)
    m_score := m_score + 30
if (hist_deriv > 0)
    m_score := m_score + 40
if (rsi_val < 50)
    m_score := m_score - 30
if (macd_hist < 0)
    m_score := m_score - 30
if (hist_deriv < 0)
    m_score := m_score - 40

float v_score = is_vol_spike ? (close >= open ? 100.0 : -100.0) : (close >= open ? 40.0 : -40.0)
float s_score = bullish_bos ? 100.0 : bearish_bos ? -100.0 : 0.0
float smc_score = bullish_fvg ? 100.0 : bearish_fvg ? -100.0 : 0.0
float volatility_score = is_squeezed ? 50.0 : 0.0
float mtf_score_val = htf_trend_bullish ? 100.0 : -100.0

float final_bull = 0.0
float final_bear = 0.0

if (enable_trend)
    final_bull := final_bull + (math.max(0.0, t_score) * w_trend)
    final_bear := final_bear + (math.max(0.0, -t_score) * w_trend)
if (enable_momen)
    final_bull := final_bull + (math.max(0.0, m_score) * w_momen)
    final_bear := final_bear + (math.max(0.0, -m_score) * w_momen)
if (enable_volum)
    final_bull := final_bull + (math.max(0.0, v_score) * w_volum)
    final_bear := final_bear + (math.max(0.0, -v_score) * w_volum)
if (enable_struct)
    final_bull := final_bull + (math.max(0.0, s_score) * w_struct)
    final_bear := final_bear + (math.max(0.0, -s_score) * w_struct)
if (enable_smc)
    final_bull := final_bull + (math.max(0.0, smc_score) * w_smc)
    final_bear := final_bear + (math.max(0.0, -smc_score) * w_smc)
if (enable_volat)
    final_bull := final_bull + (math.max(0.0, volatility_score) * w_volat)
    final_bear := final_bear + (math.max(0.0, -volatility_score) * w_volat)
if (enable_mtf)
    final_bull := final_bull + (math.max(0.0, mtf_score_val) * w_mtf)
    final_bear := final_bear + (math.max(0.0, -mtf_score_val) * w_mtf)

int bullish_confidence = math.round(final_bull)
int bearish_confidence = math.round(final_bear)

// =========================================================================
// 10. HARD VETO guards
// =========================================================================
bool veto_long = false
bool veto_short = false
string veto_reason = "None"
float overextension_limit = sys_mode == "CONSERVATIVE" ? 1.5 : sys_mode == "BALANCED" ? 2.25 : 3.0

if (not htf_trend_bullish and sys_mode == "CONSERVATIVE")
    veto_long := true
    veto_reason := "HTF Trend Opposition"
else if (close > vwap_val + (overextension_limit * atr))
    veto_long := true
    veto_reason := "Extreme Upside Overextension"
else if (regime_type == 3)
    veto_long := true
    veto_reason := "Volatile Disorder"
else if (not in_session)
    veto_long := true
    veto_reason := "Outside Session Limits"

if (htf_trend_bullish and sys_mode == "CONSERVATIVE")
    veto_short := true
    veto_reason := "HTF Trend Opposition"
else if (close < vwap_val - (overextension_limit * atr))
    veto_short := true
    veto_reason := "Extreme Downside Overextension"
else if (regime_type == 3)
    veto_short := true
    veto_reason := "Volatile Disorder"
else if (not in_session)
    veto_short := true
    veto_reason := "Outside Session Limits"

// =========================================================================
// 11. SIGNAL FILTER & RISK ENGINE
// =========================================================================
int buy_threshold = sys_mode == "CONSERVATIVE" ? 75 : sys_mode == "BALANCED" ? 65 : 55
int sell_threshold = sys_mode == "CONSERVATIVE" ? 75 : sys_mode == "BALANCED" ? 65 : 55

bool buy_trigger = bullish_confidence >= buy_threshold and not veto_long and barstate.isconfirmed
bool sell_trigger = bearish_confidence >= sell_threshold and not veto_short and barstate.isconfirmed

var int last_signal_bar = 0
bool cooldown_ok = (bar_index - last_signal_bar) >= 5

bool exec_buy = buy_trigger and cooldown_ok
bool exec_sell = sell_trigger and cooldown_ok

if (exec_buy or exec_sell)
    last_signal_bar := bar_index

var float stop_loss = na
var float target_1 = na
var float target_2 = na
var float target_3 = na
var string signal_state = "Neutral"

if (exec_buy)
    signal_state := "STRONG BUY"
    stop_loss := math.min(close - (atr_stop_m * atr), nz(swing_low, close * 0.95))
    float risk = close - stop_loss
    target_1 := close + (1.0 * risk)
    target_2 := close + (2.0 * risk)
    target_3 := close + (3.0 * risk)
else if (exec_sell)
    signal_state := "STRONG SELL"
    stop_loss := math.max(close + (atr_stop_m * atr), nz(swing_high, close * 1.05))
    float risk = stop_loss - close
    target_1 := close - (1.0 * risk)
    target_2 := close - (2.0 * risk)
    target_3 := close - (3.0 * risk)

// R:R check
float est_rr = stop_loss != close ? math.abs(target_2 - close) / math.abs(close - stop_loss) : 0.0
bool rr_valid = est_rr >= min_rr
if (not rr_valid and (exec_buy or exec_sell))
    exec_buy := false
    exec_sell := false
    signal_state := "NEUTRAL (R:R Rejected)"

// =========================================================================
// 12. TELEMETRY DISPLAY DASHBOARD
// =========================================================================
var table dash = table.new(get_position(dash_pos), 10, 12, border_color=color.new(#1e293b, 0), border_width=1)

if (show_dash and barstate.islast)
    table.cell(dash, 0, 0, "ALADDIN AI CONFLUENCE MATRIX", text_color=color.white, bgcolor=color.new(#1e293b, 0), text_size=size.normal, text_halign=text.align_center)
    table.merge_cells(dash, 0, 0, 1, 0)
    
    cell_format(dash, 0, 1, "Market Regime", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 1, regime, regime_type == 1 ? color.green : regime_type == 0 ? color.orange : color.red, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 2, "Trend Score", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 2, str.tostring(t_score, "#.##") + "/100", t_score >= 0 ? color.green : color.red, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 3, "Momentum Score", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 3, str.tostring(m_score, "#.##") + "/100", m_score >= 0 ? color.green : color.red, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 4, "Participation (RVOL)", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 4, str.tostring(rvol, "#.##") + "x", rvol >= 1.5 ? color.green : color.orange, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 5, "Demand Imbalance", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 5, str.tostring(buy_pct, "#.#") + "% B / " + str.tostring(sell_pct, "#.#") + "% S", buy_pct >= 50.0 ? color.green : color.red, color.new(#0f172a, 0))

    cell_format(dash, 0, 6, "Structure Alignment", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 6, structure_brief, struct_color, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 7, "Bullish Probability", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 7, str.tostring(bullish_confidence) + "%", color.green, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 8, "Bearish Probability", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 8, str.tostring(bearish_confidence) + "%", color.red, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 9, "Veto Status", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 9, veto_long or veto_short ? veto_reason : "None", veto_long or veto_short ? color.red : color.green, color.new(#0f172a, 0))

    cell_format(dash, 0, 10, "Decision Output", color.white, color.new(#1e293b, 0))
    cell_format(dash, 1, 10, signal_state, signal_state == "STRONG BUY" ? color.green : signal_state == "STRONG SELL" ? color.red : color.orange, color.new(#1e293b, 0))

// =========================================================================
// 13. PLOTS & DRAWINGS
// =========================================================================
plot(ema_fast, title="Fast EMA", color=color.new(#3b82f6, 0), linewidth=1)
plot(sma_slow, title="Slow SMA", color=color.new(#f59e0b, 0), linewidth=2)

// Hidden plots for alert condition placeholders (Plot 2 and Plot 3)
plot(stop_loss, title="Stop Loss Plot", display=display.none)
plot(target_2, title="Target Plot", display=display.none)

plotshape(exec_buy, title="Buy Shape", style=shape.triangleup, location=location.belowbar, color=color.new(#10b981, 0), size=size.normal, text="BUY", textcolor=color.white)
plotshape(exec_sell, title="Sell Shape", style=shape.triangledown, location=location.abovebar, color=color.new(#ef4444, 0), size=size.normal, text="SELL", textcolor=color.white)

// Highlight Candlestick Patterns
barcolor(is_bullish_engulfing ? color.new(#10b981, 60) : is_bearish_engulfing ? color.new(#ef4444, 60) : na)

// =========================================================================
// 14. ALERTS CONFIGURATION
// =========================================================================
alertcondition(exec_buy, title="Buy Alert", message='{"event": "BUY", "ticker": "{{ticker}}", "price": "{{close}}", "stop": "{{plot_2}}", "target": "{{plot_3}}"}')
alertcondition(exec_sell, title="Sell Alert", message='{"event": "SELL", "ticker": "{{ticker}}", "price": "{{close}}", "stop": "{{plot_2}}", "target": "{{plot_3}}"}')

// Modern dynamic alert calls
if exec_buy
    alert('{"event": "BUY", "ticker": "' + syminfo.ticker + '", "price": "' + str.tostring(close) + '", "stop": "' + str.tostring(stop_loss) + '", "target": "' + str.tostring(target_2) + '"}', alert.freq_once_per_bar_close)
if exec_sell
    alert('{"event": "SELL", "ticker": "' + syminfo.ticker + '", "price": "' + str.tostring(close) + '", "stop": "' + str.tostring(stop_loss) + '", "target": "' + str.tostring(target_2) + '"}', alert.freq_once_per_bar_close)
