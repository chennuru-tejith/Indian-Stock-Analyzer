//@version=6
indicator("Aladdin Institutional F&O Broker Intelligence Engine (Nifty / Index)", shorttitle="Aladdin F&O Broker", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500)

// =========================================================================
// 1. INPUT PARAMETERS (F&O BROKER CONFIGURATIONS)
// =========================================================================
gp_sys       = "SYSTEM CONFIGURATION"
sys_mode     = input.string("BALANCED", title="Operating Mode", options=["CONSERVATIVE", "BALANCED", "AGGRESSIVE"], group=gp_sys)
min_rr       = input.float(1.5, title="Minimum Reward-to-Risk Ratio", step=0.1, group=gp_sys)

gp_fo        = "F&O BROKER RULES (NIFTY / BANKNIFTY)"
strike_step_in = input.int(50, title="Option Strike Step (Nifty: 50, BankNifty: 100)", group=gp_fo)
show_cpr     = input.bool(true, title="Show Daily Central Pivot Range (CPR)", group=gp_fo)
show_pdh_pdl = input.bool(true, title="Show Previous Day High / Low (PDH/PDL)", group=gp_fo)
show_vwap_sd = input.bool(true, title="Show VWAP StdDev Bands (1σ / 2σ)", group=gp_fo)

gp_modules   = "MODULE TOGGLES"
enable_trend = input.bool(true, title="Enable Trend Engine", group=gp_modules)
enable_momen = input.bool(true, title="Enable Momentum Engine", group=gp_modules)
enable_volum = input.bool(true, title="Enable Participation Engine", group=gp_modules)
enable_struct= input.bool(true, title="Enable Market Structure Engine", group=gp_modules)
enable_smc   = input.bool(true, title="Enable Smart Money Concepts", group=gp_modules)
enable_volat = input.bool(true, title="Enable Volatility Engine", group=gp_modules)
enable_mtf   = input.bool(true, title="Enable Multi-Timeframe Alignment", group=gp_modules)

gp_trend     = "A. TREND QUALITY"
ema_fast_len = input.int(20, title="Fast EMA Period", group=gp_trend)
sma_slow_len = input.int(200, title="Slow SMA Period", group=gp_trend)
adx_len      = input.int(14, title="ADX Period", group=gp_trend)
adx_limit    = input.int(20, title="ADX Threshold", group=gp_trend)

gp_momentum  = "B. MOMENTUM QUALITY"
rsi_len      = input.int(14, title="RSI Length", group=gp_momentum)
rsi_ob       = input.int(70, title="RSI Overbought", group=gp_momentum)
rsi_os       = input.int(30, title="RSI Oversold", group=gp_momentum)
macd_fast    = input.int(12, title="MACD Fast Period", group=gp_momentum)
macd_slow    = input.int(26, title="MACD Slow Period", group=gp_momentum)
macd_signal  = input.int(9, title="MACD Signal Period", group=gp_momentum)

gp_structure = "C. MARKET STRUCTURE"
pivot_len    = input.int(5, title="Swing Pivot Lookback", minval=2, group=gp_structure)

gp_smc       = "D. SMART MONEY CONCEPTS"
fvg_threshold= input.float(0.1, title="FVG Min Height (ATR Ratio)", step=0.05, group=gp_smc)
show_ob      = input.bool(true, title="Show Order Blocks", group=gp_smc)

gp_volatility= "E. VOLATILITY ENGINE"
atr_len      = input.int(14, title="ATR Length", group=gp_volatility)
atr_stop_m   = input.float(2.0, title="ATR Stop Loss Multiplier", step=0.1, group=gp_volatility)

gp_mtf       = "F. MULTI-TIMEFRAME ALIGNMENT"
htf_res      = input.timeframe("240", title="Higher Timeframe", group=gp_mtf)

gp_session   = "G. SESSION RULES"
use_session  = input.bool(false, title="Restrict Trading Session", group=gp_session)
session_time = input.session("0915-1530:23456", title="Trading Session Times", group=gp_session)

gp_ui        = "H. TELEMETRY DISPLAY"
show_dash    = input.bool(true, title="Show Telemetry Dashboard", group=gp_ui)
dash_pos     = input.string("top_right", title="Dashboard Position", options=["top_right", "bottom_right", "top_left", "bottom_left"], group=gp_ui)

// =========================================================================
// 2. HELPER FUNCTIONS
// =========================================================================
get_position(string pos_str) =>
    switch pos_str
        "top_right"    => position.top_right
        "bottom_right" => position.bottom_right
        "top_left"     => position.top_left
        "bottom_left"  => position.bottom_left
        => position.top_right

cell_format(table t, int col, int row, string txt, color text_c, color bg_c) =>
    table.cell(t, col, row, txt, text_color=text_c, bgcolor=bg_c, text_size=size.small, text_halign=text.align_left)

format_vol(float vol) =>
    if vol >= 1000000
        str.tostring(vol / 1000000, "#.#") + "M"
    else if vol >= 1000
        str.tostring(vol / 1000, "#.#") + "K"
    else
        str.tostring(vol, "#")

// Auto Option Strike Step Calculation
strike_step = str.contains(syminfo.ticker, "BANKNIFTY") ? 100 : strike_step_in
atm_strike  = math.round(close / strike_step) * strike_step

// =========================================================================
// 3. CORE F&O ENGINE & CPR CALCULATIONS
// =========================================================================
// Fetch Previous Day High, Low, Close for Central Pivot Range (CPR)
pdh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
pdl = request.security(syminfo.tickerid, "D", low[1], lookahead=barmerge.lookahead_on)
pdc = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)

pivot_p  = (pdh + pdl + pdc) / 3.0
pivot_bc = (pdh + pdl) / 2.0
pivot_tc = (2.0 * pivot_p) - pivot_bc

cpr_top    = math.max(pivot_tc, pivot_bc)
cpr_bottom = math.min(pivot_tc, pivot_bc)
cpr_width  = pivot_p > 0 ? ((cpr_top - cpr_bottom) / pivot_p) * 100.0 : 0.0

is_narrow_cpr = cpr_width <= 0.25
is_wide_cpr   = cpr_width >= 0.50

string cpr_status = is_narrow_cpr ? "Narrow CPR (Trending Day 🚀)" : is_wide_cpr ? "Wide CPR (Rangebound 📊)" : "Average CPR (Normal Day 🔄)"
color cpr_color  = is_narrow_cpr ? color.green : is_wide_cpr ? color.orange : color.blue

// Plot CPR Lines
plot(show_cpr ? pivot_p : na, title="CPR Pivot (P)", color=color.new(#a855f7, 20), linewidth=2)
plot(show_cpr ? cpr_top : na, title="CPR Top (TC)", color=color.new(#c084fc, 40), linewidth=1, style=plot.style_linebr)
plot(show_cpr ? cpr_bottom : na, title="CPR Bottom (BC)", color=color.new(#c084fc, 40), linewidth=1, style=plot.style_linebr)

// Plot Previous Day High & Low
plot(show_pdh_pdl ? pdh : na, title="Previous Day High (PDH)", color=color.new(#ef4444, 30), linewidth=1, style=plot.style_dashed)
plot(show_pdh_pdl ? pdl : na, title="Previous Day Low (PDL)", color=color.new(#10b981, 30), linewidth=1, style=plot.style_dashed)

// =========================================================================
// 4. TECHNICAL INDICATORS & AUTO INDEX VOLUME COMPENSATION
// =========================================================================
ema_fast = ta.ema(close, ema_fast_len)
sma_slow = ta.sma(close, sma_slow_len)
atr      = ta.atr(atr_len)

slope_fast = (ema_fast - ema_fast[5]) / (not na(atr) and atr > 0 ? atr * 5 : 1.0) * 100

// ADX & DMI
[di_plus, di_minus, adx_val] = ta.dmi(adx_len, adx_len)

// RSI & MACD
rsi_val = ta.rsi(close, rsi_len)
[macd_line, macd_sig, macd_hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)
hist_deriv = macd_hist - macd_hist[1]

// Detect if symbol is an Index or Volume is 0 (Cash Nifty Index case)
src_volume   = nz(volume, 0.0)
is_index     = syminfo.type == "index" or str.contains(syminfo.ticker, "NIFTY") or src_volume == 0
vol_sma      = ta.sma(src_volume, 20)
rvol         = (vol_sma > 0) ? src_volume / vol_sma : 1.0
is_vol_spike = is_index ? true : rvol >= 1.5

// Volume Demand Imbalance (Fallback to Price Location for Index)
candle_range   = high - low
bull_vol_ratio = candle_range > 0 ? (close - low) / candle_range : 0.5
buy_vol        = src_volume * bull_vol_ratio
sell_vol       = src_volume * (1.0 - bull_vol_ratio)
avg_buy_vol    = ta.sma(buy_vol, 14)
avg_sell_vol   = ta.sma(sell_vol, 14)
tot_vol_sum    = avg_buy_vol + avg_sell_vol
buy_pct        = tot_vol_sum > 0 ? (avg_buy_vol / tot_vol_sum) * 100 : (bull_vol_ratio * 100)
sell_pct       = 100.0 - buy_pct

// VWAP & StdDev Bands
vwap_raw = ta.vwap(close)
vwap_val = not na(vwap_raw) ? vwap_raw : ema_fast
vwap_stdev = ta.stdev(close, 20)
vwap_upper_1 = vwap_val + (1.0 * vwap_stdev)
vwap_lower_1 = vwap_val - (1.0 * vwap_stdev)
vwap_upper_2 = vwap_val + (2.0 * vwap_stdev)
vwap_lower_2 = vwap_val - (2.0 * vwap_stdev)

plot(show_vwap_sd ? vwap_val : na, title="VWAP", color=color.new(#3b82f6, 0), linewidth=2)
plot(show_vwap_sd ? vwap_upper_1 : na, title="VWAP +1σ", color=color.new(#3b82f6, 70), style=plot.style_linebr)
plot(show_vwap_sd ? vwap_lower_1 : na, title="VWAP -1σ", color=color.new(#3b82f6, 70), style=plot.style_linebr)

// =========================================================================
// 5. REGIME DETECTOR
// =========================================================================
atr_pct = (close > 0 and not na(atr)) ? (atr / close) * 100 : 0.0
bb_basis = ta.sma(close, 20)
bb_dev = ta.stdev(close, 20)
bb_upper = bb_basis + (2 * bb_dev)
bb_lower = bb_basis - (2 * bb_dev)
is_squeezed = bb_upper - bb_lower < 1.5 * ta.atr(20)

eff_num = math.abs(close - close[10])
eff_denom = 0.0
for i = 0 to 9
    eff_denom := eff_denom + math.abs(close[i] - close[i+1])
price_efficiency = eff_denom > 0 ? eff_num / eff_denom : 1.0

string regime = "Sideways / Range"
int regime_type = 0

is_trending = adx_val >= adx_limit and price_efficiency >= 0.45
is_volatile = atr_pct >= ta.sma(atr_pct, 100) * 1.5

if (is_volatile)
    regime := "Volatile Disorder ⚠️"
    regime_type := 3
else if (is_squeezed)
    regime := "Volatility Squeeze 🤐"
    regime_type := 2
else if (is_trending)
    if (close > sma_slow and slope_fast > 0)
        regime := "Strong Uptrend 📈"
        regime_type := 1
    else if (close < sma_slow and slope_fast < 0)
        regime := "Strong Downtrend 📉"
        regime_type := 1
    else
        regime := "Weak Trend / Pullback 🔄"
        regime_type := 1
else
    regime := "Sideways Range 📊"
    regime_type := 0

// =========================================================================
// 6. PRICE STRUCTURE & SMART MONEY CONCEPTS
// =========================================================================
var float swing_high = na
var float swing_low = na
var float prev_swing_high = na
var float prev_swing_low = na

ph = ta.pivothigh(high, pivot_len, pivot_len)
pl = ta.pivotlow(low, pivot_len, pivot_len)

if (not na(ph))
    prev_swing_high := swing_high
    swing_high := ph
if (not na(pl))
    prev_swing_low := swing_low
    swing_low := pl

var bool is_bullish_trend = true
bool bullish_bos = false
bool bearish_bos = false
bool bullish_choch = false
bool bearish_choch = false

if (not na(swing_high) and not na(swing_low))
    if (is_bullish_trend)
        if (close > swing_high and nz(close[1]) <= swing_high)
            bullish_bos := true
        else if (close < swing_low and nz(close[1]) >= swing_low)
            bearish_choch := true
            is_bullish_trend := false
    else
        if (close < swing_low and nz(close[1]) >= swing_low)
            bearish_bos := true
        else if (close > swing_high and nz(close[1]) <= swing_high)
            bullish_choch := true
            is_bullish_trend := true

// FVG & Liquidity Sweeps (Stop Hunts)
bool bullish_fvg = low[0] > high[2] and (low[0] - high[2]) > (fvg_threshold * atr)
bool bearish_fvg = high[0] < low[2] and (low[2] - high[0]) > (fvg_threshold * atr)

bool bull_liquidity_sweep = (not na(swing_low) and low < swing_low and close > swing_low) or (low < pdl and close > pdl)
bool bear_liquidity_sweep = (not na(swing_high) and high > swing_high and close < swing_high) or (high > pdh and close < pdh)

// Order Blocks
var box bullish_ob_box = na
var box bearish_ob_box = na
if (bullish_bos and show_ob)
    box.delete(bullish_ob_box)
    bullish_ob_box := box.new(left=bar_index - 5, top=nz(high[5], high), right=bar_index, bottom=nz(low[5], low), border_color=color.new(#10b981, 80), bgcolor=color.new(#10b981, 95))
if (bearish_bos and show_ob)
    box.delete(bearish_ob_box)
    bearish_ob_box := box.new(left=bar_index - 5, top=nz(high[5], high), right=bar_index, bottom=nz(low[5], low), border_color=color.new(#ef4444, 80), bgcolor=color.new(#ef4444, 95))

// =========================================================================
// 7. MULTI-TIMEFRAME ANALYSIS
// =========================================================================
htf_ema_fast = request.security(syminfo.tickerid, htf_res, ta.ema(close, ema_fast_len)[1], barmerge.gaps_off, barmerge.lookahead_off)
htf_sma_slow = request.security(syminfo.tickerid, htf_res, ta.sma(close, sma_slow_len)[1], barmerge.gaps_off, barmerge.lookahead_off)
htf_rsi      = request.security(syminfo.tickerid, htf_res, ta.rsi(close, 14)[1], barmerge.gaps_off, barmerge.lookahead_off)
htf_trend_bullish = htf_ema_fast > htf_sma_slow

// =========================================================================
// 8. AI CONFLUENCE SCORING ENGINE
// =========================================================================
float w_trend  = 0.25
float w_momen  = 0.20
float w_volum  = is_index ? 0.05 : 0.15
float w_struct = 0.20
float w_smc    = 0.15
float w_volat  = 0.05
float w_mtf    = 0.10

// Trend Score
float t_score = 0.0
if (close > ema_fast) t_score := t_score + 40
if (close > sma_slow) t_score := t_score + 40
if (slope_fast > 0)   t_score := t_score + 20
if (close < ema_fast) t_score := t_score - 40
if (close < sma_slow) t_score := t_score - 40
if (slope_fast < 0)   t_score := t_score - 20

// Momentum Score
float m_score = 0.0
if (rsi_val > 50) m_score := m_score + 30
if (macd_hist > 0) m_score := m_score + 30
if (hist_deriv > 0) m_score := m_score + 40
if (rsi_val < 50) m_score := m_score - 30
if (macd_hist < 0) m_score := m_score - 30
if (hist_deriv < 0) m_score := m_score - 40

// Participation / VWAP Score
float v_score = 0.0
if (close > vwap_val) v_score := v_score + 50
else v_score := v_score - 50

if (close > cpr_top) v_score := v_score + 50
else if (close < cpr_bottom) v_score := v_score - 50

// Structure & SMC Scores
float s_score = bullish_bos ? 100.0 : bearish_bos ? -100.0 : 0.0

float smc_score = 0.0
if (bullish_fvg) smc_score := smc_score + 50.0
if (bearish_fvg) smc_score := smc_score - 50.0
if (bull_liquidity_sweep) smc_score := smc_score + 50.0
if (bear_liquidity_sweep) smc_score := smc_score - 50.0

float volatility_score = is_squeezed ? 50.0 : 0.0

float mtf_score_val = 0.0
if (htf_trend_bullish) mtf_score_val := mtf_score_val + 60.0
else mtf_score_val := mtf_score_val - 60.0
if (not na(htf_rsi) and htf_rsi > 50) mtf_score_val := mtf_score_val + 40.0
else if (not na(htf_rsi) and htf_rsi < 50) mtf_score_val := mtf_score_val - 40.0

float final_bull = 0.0
float final_bear = 0.0
float active_weights_sum = 0.0

if (enable_trend)
    final_bull := final_bull + (math.max(0.0, t_score) * w_trend)
    final_bear := final_bear + (math.max(0.0, -t_score) * w_trend)
    active_weights_sum := active_weights_sum + w_trend
if (enable_momen)
    final_bull := final_bull + (math.max(0.0, m_score) * w_momen)
    final_bear := final_bear + (math.max(0.0, -m_score) * w_momen)
    active_weights_sum := active_weights_sum + w_momen
if (enable_volum)
    final_bull := final_bull + (math.max(0.0, v_score) * w_volum)
    final_bear := final_bear + (math.max(0.0, -v_score) * w_volum)
    active_weights_sum := active_weights_sum + w_volum
if (enable_struct)
    final_bull := final_bull + (math.max(0.0, s_score) * w_struct)
    final_bear := final_bear + (math.max(0.0, -s_score) * w_struct)
    active_weights_sum := active_weights_sum + w_struct
if (enable_smc)
    final_bull := final_bull + (math.max(0.0, smc_score) * w_smc)
    final_bear := final_bear + (math.max(0.0, -smc_score) * w_smc)
    active_weights_sum := active_weights_sum + w_smc
if (enable_volat)
    final_bull := final_bull + (math.max(0.0, volatility_score) * w_volat)
    final_bear := final_bear + (math.max(0.0, -volatility_score) * w_volat)
    active_weights_sum := active_weights_sum + w_volat
if (enable_mtf)
    final_bull := final_bull + (math.max(0.0, mtf_score_val) * w_mtf)
    final_bear := final_bear + (math.max(0.0, -mtf_score_val) * w_mtf)
    active_weights_sum := active_weights_sum + w_mtf

float norm_factor = active_weights_sum > 0 ? active_weights_sum : 1.0
int bullish_confidence = math.round(final_bull / norm_factor)
int bearish_confidence = math.round(final_bear / norm_factor)

// =========================================================================
// 9. SIGNAL FILTER & F&O BROKER STRATEGY SELECTION
// =========================================================================
int buy_threshold = sys_mode == "CONSERVATIVE" ? 75 : sys_mode == "BALANCED" ? 65 : 55
int sell_threshold = sys_mode == "CONSERVATIVE" ? 75 : sys_mode == "BALANCED" ? 65 : 55

in_session = not use_session or not na(time(timeframe.period, session_time))

bool veto_long = close > vwap_upper_2 or regime_type == 3 or not in_session
bool veto_short = close < vwap_lower_2 or regime_type == 3 or not in_session

bool buy_trigger = bullish_confidence >= buy_threshold and not veto_long and barstate.isconfirmed
bool sell_trigger = bearish_confidence >= sell_threshold and not veto_short and barstate.isconfirmed

var int last_signal_bar = 0
bool cooldown_ok = (bar_index - last_signal_bar) >= 5

bool exec_buy = buy_trigger and cooldown_ok
bool exec_sell = sell_trigger and cooldown_ok

if (exec_buy or exec_sell)
    last_signal_bar := bar_index

var float stop_loss = na
var float target_2 = na
var string fo_action = "NO TRADE (HOLD / WAIT)"

if (exec_buy)
    stop_loss := math.min(close - (atr_stop_m * atr), nz(swing_low, close * 0.99))
    float risk = close - stop_loss
    target_2 := close + (2.0 * risk)
    fo_action := "BUY " + str.tostring(atm_strike) + " CE (CALL)"
else if (exec_sell)
    stop_loss := math.max(close + (atr_stop_m * atr), nz(swing_high, close * 1.01))
    float risk = stop_loss - close
    target_2 := close - (2.0 * risk)
    fo_action := "BUY " + str.tostring(atm_strike) + " PE (PUT)"

// =========================================================================
// 10. INSTITUTIONAL TELEMETRY DISPLAY BOARD
// =========================================================================
var table dash = table.new(get_position(dash_pos), 10, 11, border_color=color.new(#1e293b, 0), border_width=1)

if (show_dash and barstate.islast)
    table.cell(dash, 0, 0, "ALADDIN F&O BROKER TERMINAL (" + syminfo.ticker + ")", text_color=color.white, bgcolor=color.new(#1e293b, 0), text_size=size.normal, text_halign=text.align_center)
    table.merge_cells(dash, 0, 0, 1, 0)
    
    cell_format(dash, 0, 1, "CPR Regime", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 1, cpr_status, cpr_color, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 2, "Trend / Momentum", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 2, regime, regime_type == 1 ? color.green : color.orange, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 3, "ATM Strike", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 3, str.tostring(atm_strike) + " ATM", color.yellow, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 4, "VWAP Location", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 4, close > vwap_val ? "Above VWAP (Bullish)" : "Below VWAP (Bearish)", close > vwap_val ? color.green : color.red, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 5, "Demand Bias", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 5, str.tostring(buy_pct, "#.0") + "% BUY / " + str.tostring(sell_pct, "#.0") + "% SELL", buy_pct >= 50.0 ? color.green : color.red, color.new(#0f172a, 0))

    cell_format(dash, 0, 6, "Bullish Prob (CE)", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 6, str.tostring(bullish_confidence) + "%", color.green, color.new(#0f172a, 0))
    
    cell_format(dash, 0, 7, "Bearish Prob (PE)", color.white, color.new(#0f172a, 0))
    cell_format(dash, 1, 7, str.tostring(bearish_confidence) + "%", color.red, color.new(#0f172a, 0))

    cell_format(dash, 0, 8, "F&O Action Call", color.white, color.new(#1e293b, 0))
    cell_format(dash, 1, 8, fo_action, exec_buy ? color.green : exec_sell ? color.red : color.orange, color.new(#1e293b, 0))

// =========================================================================
// 11. PLOTS, LABELS, & SIGNAL TARGETS
// =========================================================================
float future_range = 1.65 * atr
p_upper = plot(close + future_range, title="AI Upper Target Band", color=color.new(#14b8a6, 85))
p_lower = plot(close - future_range, title="AI Lower Target Band", color=color.new(#14b8a6, 85))
fill(p_upper, p_lower, color=color.new(#14b8a6, 96), title="AI Confidence Channel")

plot(ema_fast, title="Fast EMA", color=color.new(#3b82f6, 0), linewidth=1)
plot(sma_slow, title="Slow SMA", color=color.new(#f59e0b, 0), linewidth=2)

var float active_sl = na
var float active_tp = na
var float active_entry = na
var int active_dir = 0

if (exec_buy)
    active_sl := stop_loss
    active_tp := target_2
    active_entry := close
    active_dir := 1
    label.new(bar_index, low - (atr * 0.75), 
              text="🟢 BUY " + str.tostring(atm_strike) + " CE\nENTRY: " + str.tostring(close, "#.##") + "\n🛑 SL: " + str.tostring(stop_loss, "#.##") + "\n🎯 TP: " + str.tostring(target_2, "#.##"), 
              color=color.new(#10b981, 10), textcolor=color.white, style=label.style_label_up, size=size.small)
else if (exec_sell)
    active_sl := stop_loss
    active_tp := target_2
    active_entry := close
    active_dir := -1
    label.new(bar_index, high + (atr * 0.75), 
              text="🔴 BUY " + str.tostring(atm_strike) + " PE\nENTRY: " + str.tostring(close, "#.##") + "\n🛑 SL: " + str.tostring(stop_loss, "#.##") + "\n🎯 TP: " + str.tostring(target_2, "#.##"), 
              color=color.new(#ef4444, 10), textcolor=color.white, style=label.style_label_down, size=size.small)

if (active_dir == 1 and (low <= active_sl or high >= active_tp))
    active_sl := na
    active_tp := na
    active_entry := na
    active_dir := 0
else if (active_dir == -1 and (high >= active_sl or low <= active_tp))
    active_sl := na
    active_tp := na
    active_entry := na
    active_dir := 0

plot(active_sl, title="Active Stop Loss Line", color=color.new(color.red, 20), style=plot.style_linebr, linewidth=2)
plot(active_entry, title="Active Entry Line", color=color.new(color.blue, 20), style=plot.style_linebr, linewidth=2)
plot(active_tp, title="Active Target Line", color=color.new(color.green, 20), style=plot.style_linebr, linewidth=2)

plotshape(exec_buy, title="Buy Shape", style=shape.triangleup, location=location.belowbar, color=color.new(#10b981, 0), size=size.normal, text="BUY CE", textcolor=color.white)
plotshape(exec_sell, title="Sell Shape", style=shape.triangledown, location=location.abovebar, color=color.new(#ef4444, 0), size=size.normal, text="SELL PE", textcolor=color.white)
